{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precommit-check.sh",
            "if": "Bash(git commit *)",
            "timeout": 120,
            "statusMessage": "Running pre-commit CI gate (ruff + pytest)"
          }
        ]
      }
    ]
  }
}
