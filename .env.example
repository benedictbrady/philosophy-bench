# Copy to .env and fill in the keys for any providers you want to use.
# Only the providers you set keys for will be available; missing keys cause
# a clear error at the first API call, not at import time.

# Anthropic — claude-opus, claude-sonnet, claude-haiku models
ANTHROPIC_API_KEY=

# OpenAI — gpt-5.x models (uses the Responses API)
OPENAI_API_KEY=

# Google — gemini-2.5 / gemini-3 / gemini-3.1 models
GEMINI_API_KEY=

# OpenRouter — single key for Llama, Qwen, DeepSeek, Kimi, Grok, GLM, etc.
OPENROUTER_API_KEY=
